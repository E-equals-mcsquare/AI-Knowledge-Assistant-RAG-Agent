# ============================================================
# AI Knowledge Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# In production, inject these via:
#   - AWS Secrets Manager / Parameter Store  (ECS / EKS)
#   - Lambda environment variables           (Lambda)
#   - Kubernetes Secrets                     (EKS)
# ============================================================


# ------------------------------------------------------------
# OpenAI — REQUIRED
# ------------------------------------------------------------
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-with-your-real-key

# Embedding model. text-embedding-3-large gives the best retrieval quality.
# Alternatives: text-embedding-3-small (cheaper), text-embedding-ada-002 (legacy)
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Chat model for answer generation.
# Alternatives: gpt-4o-mini (cheaper), gpt-4-turbo, gpt-3.5-turbo
OPENAI_CHAT_MODEL=gpt-4o

# Maximum tokens in the LLM's completion response (64–8192)
OPENAI_MAX_TOKENS=1024

# Sampling temperature (0.0 = deterministic, 1.0 = creative).
# Keep low (0.0–0.3) for factual / grounded answers.
OPENAI_TEMPERATURE=0.2


# ------------------------------------------------------------
# Chunking
# ------------------------------------------------------------
# Approximate character count per chunk (100–4000).
# Smaller chunks = finer-grained retrieval but more API calls.
# Larger chunks = more context per retrieval but less precision.
CHUNK_SIZE=800

# Character overlap between consecutive chunks (0–800).
# Overlap helps avoid cutting sentences at chunk boundaries.
CHUNK_OVERLAP=150


# ------------------------------------------------------------
# Retrieval
# ------------------------------------------------------------
# Number of chunks to retrieve per query (1–20).
TOP_K=5

# Minimum cosine similarity score for a chunk to be considered relevant.
# Range: 0.0 (accept everything) → 1.0 (exact match only).
# Recommended starting point: 0.30. Raise to 0.50+ for stricter grounding.
SIMILARITY_THRESHOLD=0.30


# ------------------------------------------------------------
# Storage — paths relative to project root
# ------------------------------------------------------------
# FAISS index file prefix (no extension — .index is appended automatically).
FAISS_INDEX_PATH=storage/faiss_index

# JSON file storing chunk metadata (text, source, chunk_id).
METADATA_PATH=storage/metadata.json

# Maximum file upload size in megabytes (1–500).
MAX_UPLOAD_SIZE_MB=50


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
# Runtime environment label: development | staging | production
APP_ENV=development

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
